# Flutter/Dart/Pub related
# Libraries should not include pubspec.lock, per https://dart.dev/guides/libraries/private-files#pubspeclock.
/pubspec.lock
**/doc/api/
/doc/
.dart_tool/
.flutter-plugins-dependencies
.flutter-plugins
.pub/
/build/
**/build/
/coverage/

# Local pub overrides (path/git experiments) — do not commit
pubspec_overrides.yaml

# Android / Gradle (caches; never commit)
**/.gradle/

# Android local SDK paths
**/local.properties

# Profiling / dumps
*.hprof
